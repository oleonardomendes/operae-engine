{
  "_instrucoes": "Copie este arquivo para store-configs/<store-id>/store-config.json e preencha os campos. Campos com 'env:VAR_NAME' leem de variáveis de ambiente. Este campo _instrucoes é ignorado em produção.",

  "store_id": "<identificador-unico-da-loja>",
  "nome": "<Nome da Loja>",
  "dominio": "<dominio.com.br>",
  "regime": "SN",

  "tema": {
    "cor_primaria": "#000000",
    "cor_secundaria": "#ffffff",
    "logo_url": "",
    "favicon_url": ""
  },

  "bling": {
    "client_id": "env:BLING_CLIENT_ID",
    "client_secret": "env:BLING_CLIENT_SECRET"
  },

  "mercado_pago": {
    "public_key": "env:MP_PUBLIC_KEY",
    "webhook_secret": "env:MP_WEBHOOK_SECRET"
  },

  "melhor_envio": {
    "sandbox": false,
    "from_nome": "",
    "from_cep": "",
    "from_rua": "",
    "from_numero": "",
    "from_bairro": "",
    "from_cidade": "",
    "from_uf": ""
  },

  "resend": {
    "api_key": "env:RESEND_API_KEY",
    "from": "<Nome da Loja> <email@dominio.com.br>"
  },

  "precificacao": {
    "margem_ml": 0.30,
    "margem_shopee": 0.28,
    "margem_site": 0.40,
    "desconto_pix": 0.05,
    "taxa_ml": 0.14,
    "taxa_shopee": 0.16
  },

  "analytics": {
    "gtm_id": "",
    "meta_pixel_id": "",
    "ga4_id": "",
    "tiktok_pixel_id": "",
    "google_ads_id": ""
  },

  "supabase": {
    "url": "env:NEXT_PUBLIC_SUPABASE_URL",
    "anon_key": "env:NEXT_PUBLIC_SUPABASE_ANON_KEY"
  },

  "contato": {
    "email": "contato@<dominio.com.br>",
    "whatsapp": "<DDI+DDD+numero, apenas dígitos, ex: 5511999999999>",
    "instagram_url": "https://www.instagram.com/<handle>/",
    "facebook_url": "https://www.facebook.com/<handle>/"
  }
}
